# Copy this file to .env and fill in your values. Never commit .env.

# Bot token from https://discord.com/developers/applications -> your app -> Bot
DISCORD_TOKEN=your-token-here

# Optional: comma-separated server (guild) IDs to sync slash commands to.
# Guild-scoped sync is instant; leaving this empty syncs globally (can take up to an hour).
GUILD_IDS=

# Optional: where the SQLite database lives (default: data/bot.db).
# DB_PATH=data/bot.db
